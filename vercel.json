{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    { "src": "/api/gemini", "dest": "/api/gemini.js" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/app.js", "dest": "/app.js" },
    { "src": "/style.css", "dest": "/style.css" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
